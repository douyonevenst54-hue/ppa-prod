// prisma/schema.prisma
//
// Source of truth: the live ppa_production Neon database
// (introspected via `prisma db pull` on 2026-05-22).
//
// Patches applied on top of the introspection:
//   1. @default(cuid()) restored on every model's id (introspection strips
//      these because Postgres just sees text columns).
//   2. Auto-named relations (e.g. `Content Content`) renamed to lowercase
//      conventions that match how application code accesses them
//      (e.g. `content.predictions`, `user.results`).
//   3. Nothing else changed. No new fields, no new tables, no schema
//      changes that aren't already in the DB. Migrations untouched.
//
// If you need to add fields (explanation, source, createdBy, etc.) or
// new tables (AIGenerationLog, AIContentDraft), do so via a proper
// migration in a separate PR. Do not append duplicate model blocks.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Core user & content
// ---------------------------------------------------------------------------

model User {
  id                 String   @id @default(cuid())
  piUserId           String   @unique
  username           String   @unique
  ppaBalance         Int      @default(100)
  accuracyRate       Float    @default(0)
  reputationScore    Float    @default(0)
  streakDays         Int      @default(0)
  lastActiveDate     DateTime?
  lastStreakDate     DateTime?
  longestStreak      Int      @default(0)
  tier               UserTier @default(NEWCOMER)
  totalPredictions   Int      @default(0)
  correctPredictions Int      @default(0)
  totalChallenges    Int      @default(0)
  correctChallenges  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  results      ChallengeResult[]
  createdContent      Content[]
  transactions PPATransaction[]
  pollVotes    PollVote[]
  predictions  Prediction[]
}

model Content {
  id               String        @id @default(cuid())
  creatorId        String
  title            String
  category         Category
  status           ContentStatus @default(PENDING)
  type             String
  endsAt           DateTime
  rewardPool       Int           @default(0)
  participantCount Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  creator     User         @relation(fields: [creatorId], references: [id])
  pollOptions PollOption[]
  predictions Prediction[]
  questions   Question[]
}

model Question {
  id            String     @id @default(cuid())
  contentId     String?
  text          String
  options       Json
  correctAnswer String
  category      Category
  difficulty    Difficulty
  qualityScore  Int        @default(0)
  timesServed   Int        @default(0)
  timesCorrect  Int        @default(0)
  createdAt     DateTime   @default(now())

  content Content?          @relation(fields: [contentId], references: [id])
  results ChallengeResult[]
}

model ChallengeResult {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  isCorrect   Boolean
  timeSeconds Int
  ppaEarned   Int      @default(0)
  streakBonus Int      @default(0)
  createdAt   DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model Prediction {
  id              String   @id @default(cuid())
  userId          String
  contentId       String
  answer          String
  confidenceLevel Int
  stakeAmount     Int
  potentialReward Int
  isCorrect       Boolean?
  ppaEarned       Int      @default(0)
  createdAt       DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model PollOption {
  id        String   @id @default(cuid())
  contentId String
  text      String
  voteCount Int      @default(0)
  createdAt DateTime @default(now())

  content Content    @relation(fields: [contentId], references: [id])
  votes   PollVote[]
}

model PollVote {
  id           String   @id @default(cuid())
  userId       String
  pollOptionId String
  ppaWeight    Int      @default(0)
  createdAt    DateTime @default(now())

  pollOption PollOption @relation(fields: [pollOptionId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([userId, pollOptionId])
}

model PPATransaction {
  id             String   @id @default(cuid())
  userId         String
  amount         Int
  type           String
  source         String
  createdAt      DateTime @default(now())
  balanceAfter   Int?
  prevHash       String?
  rowHash        String?  @unique
  idempotencyKey String?  @unique
  isSnapshot     Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, isSnapshot])
}

// ---------------------------------------------------------------------------
// PPA Ecosystem Registry
// ---------------------------------------------------------------------------

model PPAApp {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  url         String
  logoUrl     String?
  apiKey      String    @unique
  apiKeyHash  String?   @unique
  status      AppStatus @default(ACTIVE)
  category    String    @default("GENERAL")
  totalEarned Int       @default(0)
  totalSpent  Int       @default(0)
  userCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mandates     AgentMandate[]
  transactions EcosystemTransaction[]
}

model EcosystemTransaction {
  id        String   @id @default(cuid())
  appId     String
  piUserId  String
  username  String
  amount    Int
  type      String
  source    String
  createdAt DateTime @default(now())

  app PPAApp @relation(fields: [appId], references: [id])
}

// ---------------------------------------------------------------------------
// Agent mandate system
// ---------------------------------------------------------------------------

model AgentMandate {
  id            String        @id @default(cuid())
  piUserId      String
  agentId       String
  appId         String
  scope         Json
  cap           Int
  spent         Int           @default(0)
  perTxCap      Int?
  rateLimit     Json?
  notBefore     DateTime
  expiresAt     DateTime
  status        MandateStatus @default(ACTIVE)
  signature     String
  signingKeyId  String
  nonceSalt     String
  issuedAt      DateTime      @default(now())
  revokedAt     DateTime?
  revokedReason String?

  app        PPAApp         @relation(fields: [appId], references: [id])
  signingKey UserSigningKey @relation(fields: [signingKeyId], references: [id])
  audits     AgentAudit[]
  nonces     MandateNonce[]

  @@index([appId, status])
  @@index([expiresAt])
  @@index([piUserId, status])
}

model AgentAudit {
  id        String          @id @default(cuid())
  mandateId String?
  piUserId  String
  agentId   String
  appId     String
  eventType AgentAuditEvent
  payload   Json
  prevHash  String
  rowHash   String          @unique
  createdAt DateTime        @default(now())

  mandate AgentMandate? @relation(fields: [mandateId], references: [id])

  @@index([mandateId])
  @@index([piUserId, createdAt])
}

model MandateNonce {
  id          String    @id @default(cuid())
  mandateId   String
  nonce       String    @unique
  actionHash  String
  amount      Int
  consumed    Boolean   @default(false)
  consumedAt  DateTime?
  piPaymentId String?
  issuedAt    DateTime  @default(now())
  expiresAt   DateTime

  mandate AgentMandate @relation(fields: [mandateId], references: [id])

  @@index([expiresAt])
  @@index([mandateId, consumed])
}

model UserSigningKey {
  id        String    @id @default(cuid())
  piUserId  String
  publicKey String
  label     String?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  mandates AgentMandate[]

  @@index([piUserId])
  @@index([piUserId, revokedAt])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AgentAuditEvent {
  MANDATE_ISSUED
  MANDATE_REVOKED
  NONCE_ISSUED
  PAYMENT_VERIFIED
  PAYMENT_SETTLED
  PAYMENT_REJECTED
  CAP_HIT
  RATE_LIMIT_HIT
}

enum AppStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Category {
  SPORTS
  FINANCE
  TECH
  POLITICS
  SOCIAL
  GENERAL
}

enum ContentStatus {
  PENDING
  ACTIVE
  RESOLVED
  ARCHIVED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MandateStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  REVOKED
}

enum UserTier {
  NEWCOMER
  MEMBER
  TRUSTED
  EXPERT
  ELITE
}
