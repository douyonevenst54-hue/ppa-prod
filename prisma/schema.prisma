generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserTier {
  NEWCOMER
  MEMBER
  TRUSTED
  EXPERT
  ELITE
}

enum ContentStatus {
  PENDING
  ACTIVE
  RESOLVED
  ARCHIVED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Category {
  SPORTS
  FINANCE
  TECH
  POLITICS
  SOCIAL
  GENERAL
}

model User {
  id                 String    @id @default(cuid())
  piUserId           String    @unique
  username           String    @unique
  ppaBalance         Int       @default(100)
  accuracyRate       Float     @default(0)
  reputationScore    Float     @default(0)
  streakDays         Int       @default(0)
  lastActiveDate     DateTime?
  lastStreakDate     DateTime?
  longestStreak      Int       @default(0)
  tier               UserTier  @default(NEWCOMER)
  totalPredictions   Int       @default(0)
  correctPredictions Int       @default(0)
  totalChallenges    Int       @default(0)
  correctChallenges  Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  predictions      Prediction[]
  challengeResults ChallengeResult[]
  pollVotes        PollVote[]
  createdContent   Content[]
  transactions     PPATransaction[]
}

model Content {
  id               String        @id @default(cuid())
  creatorId        String
  title            String
  category         Category
  status           ContentStatus @default(PENDING)
  type             String
  endsAt           DateTime
  rewardPool       Int           @default(0)
  participantCount Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  creator      User         @relation(fields: [creatorId], references: [id])
  predictions  Prediction[]
  pollOptions  PollOption[]
  questions    Question[]
}

model Prediction {
  id              String   @id @default(cuid())
  userId          String
  contentId       String
  answer          String
  confidenceLevel Int
  stakeAmount     Int
  potentialReward Int
  isCorrect       Boolean?
  ppaEarned       Int      @default(0)
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  content Content @relation(fields: [contentId], references: [id])
}

model PollOption {
  id        String   @id @default(cuid())
  contentId String
  text      String
  voteCount Int      @default(0)
  createdAt DateTime @default(now())

  content Content    @relation(fields: [contentId], references: [id])
  votes   PollVote[]
}

model PollVote {
  id           String   @id @default(cuid())
  userId       String
  pollOptionId String
  ppaWeight    Int      @default(0)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  pollOption PollOption @relation(fields: [pollOptionId], references: [id])

  @@unique([userId, pollOptionId])
}

model Question {
  id            String     @id @default(cuid())
  contentId     String?
  text          String
  options       Json
  correctAnswer String
  category      Category
  difficulty    Difficulty
  qualityScore  Int        @default(0)
  timesServed   Int        @default(0)
  timesCorrect  Int        @default(0)
  createdAt     DateTime   @default(now())

  content  Content?          @relation(fields: [contentId], references: [id])
  results  ChallengeResult[]
}

model ChallengeResult {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  isCorrect   Boolean
  timeSeconds Int
  ppaEarned   Int      @default(0)
  streakBonus Int      @default(0)
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}

model PPATransaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Int                                    // delta: positive=credit, negative=debit
  type            String                                 // earn | spend | exchange | snapshot | mandate
  source          String                                 // poll | prediction | challenge | streak | pi_payment | mandate:<mandateId> | snapshot
  createdAt       DateTime @default(now())

  // ---- ledger fields (added in add_mandate_layer_and_ledger_chain) ----
  balanceAfter    Int?                                   // user's balance immediately after this row was applied
  prevHash        String?                                // sha256 hex of previous row for this user; "0"*64 for first
  rowHash         String?  @unique                       // sha256(prevHash || canonical(payload) || createdAt)
  idempotencyKey  String?  @unique                       // optional, for retry safety
  isSnapshot      Boolean  @default(false)               // true for the per-user genesis snapshot row

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, isSnapshot])
}

model PPAApp {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  url         String
  logoUrl     String?
  apiKey      String   @unique
  apiKeyHash  String?  @unique                           // transitional: callers will verify against hash
  status      AppStatus @default(ACTIVE)
  category    String   @default("GENERAL")
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  userCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  transactions EcosystemTransaction[]
  mandates     AgentMandate[]
}

model EcosystemTransaction {
  id        String   @id @default(cuid())
  appId     String
  app       PPAApp   @relation(fields: [appId], references: [id])
  piUserId  String
  username  String
  amount    Int
  type      String   // earn | spend | exchange
  source    String
  createdAt DateTime @default(now())
}

enum AppStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}


// =============================================================================
// Mandate + Ledger layer (migration: add_mandate_layer_and_ledger_chain)
// =============================================================================

model UserSigningKey {
  id          String    @id @default(cuid())
  piUserId    String                                     // matches User.piUserId
  publicKey   String                                     // 32-byte ed25519 public key, base64
  label       String?                                    // optional UX label like "Phone", "Backup"
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  mandates    AgentMandate[]

  @@index([piUserId])
  @@index([piUserId, revokedAt])
}

enum MandateStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  REVOKED
}

model AgentMandate {
  id            String         @id @default(cuid())
  piUserId      String                                   // matches User.piUserId
  agentId       String                                   // identifier of the AI agent
  appId         String                                   // PPAApp.id this mandate covers
  scope         Json                                     // see ScopeShape in @/types/mandate
  cap           Int                                      // total PPA spendable across mandate lifetime
  spent         Int            @default(0)
  perTxCap      Int?                                     // optional per-transaction cap
  rateLimit     Json?                                    // { windowSeconds, maxTx } or null
  notBefore     DateTime
  expiresAt     DateTime
  status        MandateStatus  @default(ACTIVE)
  signature     String                                   // base64 ed25519 sig over canonical JSON
  signingKeyId  String                                   // FK -> UserSigningKey.id
  nonceSalt     String                                   // 32-byte hex, makes mandates unique
  issuedAt      DateTime       @default(now())
  revokedAt     DateTime?
  revokedReason String?

  signingKey  UserSigningKey @relation(fields: [signingKeyId], references: [id])
  app         PPAApp         @relation(fields: [appId], references: [id])
  nonces      MandateNonce[]
  audits      AgentAudit[]

  @@index([piUserId, status])
  @@index([appId, status])
  @@index([expiresAt])
}

model MandateNonce {
  id           String    @id @default(cuid())
  mandateId    String
  nonce        String    @unique                         // 32-byte hex
  actionHash   String                                    // sha256 of {appId, action, amount, targetId}
  amount       Int
  consumed     Boolean   @default(false)
  consumedAt   DateTime?
  piPaymentId  String?                                   // Pi payment ID once settled
  issuedAt     DateTime  @default(now())
  expiresAt    DateTime                                  // short — 60s default

  mandate AgentMandate @relation(fields: [mandateId], references: [id])

  @@index([mandateId, consumed])
  @@index([expiresAt])
}

enum AgentAuditEvent {
  MANDATE_ISSUED
  MANDATE_REVOKED
  NONCE_ISSUED
  PAYMENT_VERIFIED
  PAYMENT_SETTLED
  PAYMENT_REJECTED
  CAP_HIT
  RATE_LIMIT_HIT
}

model AgentAudit {
  id        String           @id @default(cuid())
  mandateId String?
  piUserId  String                                       // matches User.piUserId
  agentId   String
  appId     String
  eventType AgentAuditEvent
  payload   Json                                         // verb-specific data
  prevHash  String                                       // sha256 of previous row for this piUserId
  rowHash   String           @unique                     // sha256(prevHash || canonical(payload) || createdAt)
  createdAt DateTime         @default(now())

  mandate AgentMandate? @relation(fields: [mandateId], references: [id])

  @@index([piUserId, createdAt])
  @@index([mandateId])
}
